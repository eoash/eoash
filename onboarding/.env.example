# 신규 입사자 온보딩 시스템 환경변수 템플릿
# 이 파일을 복사해서 .env 로 이름 변경 후 실제 값을 채워넣으세요
# cp .env.example .env
# .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 포함됨)

# Slack Bot Token
# Slack App 설정 > OAuth & Permissions > Bot User OAuth Token
# 필요 권한(scopes): channels:history, channels:read, pins:read, files:read, chat:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# Notion Integration Token
# Notion > Settings > Connections > Develop or manage integrations > New integration
# 필요 권한: Read content, No user information
NOTION_API_KEY=secret_your-notion-api-key-here

# Notion 온보딩 가이드 업로드 대상 페이지 ID (선택 - notion_upload: true 시 필요)
# Notion 페이지 URL에서 마지막 32자리 (하이픈 제외)
NOTION_UPLOAD_PAGE_ID=your-notion-upload-page-id-here
