{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/session_start.py 2>/dev/null || PYTHONUTF8=1 python \"%USERPROFILE%/.claude/hooks/session_start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/first_message.py 2>/dev/null || PYTHONUTF8=1 python \"%USERPROFILE%/.claude/hooks/first_message.py\""
          }
        ]
      }
    ]
  }
}
