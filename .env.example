# ClickUp API
CLICKUP_API_TOKEN=your_clickup_token_here

# Slack
SLACK_BOT_TOKEN=xoxb_your_token_here
SLACK_USER_ID=your_slack_user_id_here
SLACK_SIGNING_SECRET=your_signing_secret_here

# Bill.com API
BILL_COM_API_KEY=your_bill_com_api_key_here
BILL_COM_ORG_ID=your_organization_id_here

# Plaid API
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox
PLAID_ACCESS_TOKEN=your_access_token_here

# Notion
NOTION_TOKEN=ntn_your_notion_integration_token_here
NOTION_AR_DATABASE_ID=your_ar_dashboard_page_id
NOTION_THUMBNAIL_PAGE_ID=your_thumbnail_page_id_here

# Claude API
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
CLICKUP_DEFAULT_LIST_ID=your_default_list_id

# Optional: Local development
PORT=3000
