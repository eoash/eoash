# Bill.com API
BILL_COM_API_KEY=your_bill_com_api_key_here
BILL_COM_ORG_ID=your_organization_id_here

# Plaid API
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=sandbox  # or 'production'
PLAID_ACCESS_TOKEN=your_access_token_here  # Retrieved after linking account

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_DAILY=finance-ar-daily
SLACK_CHANNEL_ALERTS=finance-ar-alerts

# Notion
NOTION_TOKEN=ntn_your_notion_api_token
NOTION_AR_DATABASE_ID=your_ar_dashboard_page_id

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
